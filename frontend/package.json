{
  "name": "@ma-training/frontend",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20.12.0"
  },
  "scripts": {
    "dev": "nuxt dev --port 3000",
    "build": "nuxt build",
    "preview": "nuxt preview",
    "lint": "eslint .",
    "size": "nuxt build && size-limit",
    "test": "vitest run --passWithNoTests",
    "type-check": "vue-tsc --noEmit -p tsconfig.json"
  },
  "size-limit": [
    {
      "path": [
        ".output/public/_nuxt/**/*.js",
        ".output/public/_nuxt/**/*.css"
      ],
      "limit": "300 KB"
    }
  ],
  "dependencies": {
    "@nuxtjs/i18n": "^9.5.4",
    "@nuxtjs/tailwindcss": "^6.14.0",
    "@pinia/nuxt": "^0.9.0",
    "jsonwebtoken": "^9.0.2",
    "nuxt": "^3.17.5",
    "tailwindcss-rtl": "^0.9.0"
  },
  "devDependencies": {
    "@nuxtjs/eslint-config-typescript": "^12.1.0",
    "@types/node": "^24.7.2",
    "@vue/test-utils": "^2.4.6",
    "@size-limit/file": "^11.2.0",
    "eslint": "^8.57.1",
    "jsdom": "^27.0.0",
    "size-limit": "^11.2.0",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4",
    "vue-tsc": "^2.2.12"
  }
}
