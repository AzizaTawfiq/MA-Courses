{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "jsx": "preserve",
    "strict": true,
    "verbatimModuleSyntax": true,
    "isolatedModules": true,
    "skipLibCheck": true,
    "types": ["node"]
  },
  "include": [
    "app/**/*.vue",
    "components/**/*.vue",
    "composables/**/*.ts",
    "layouts/**/*.vue",
    "pages/**/*.vue",
    "plugins/**/*.ts",
    "server/**/*.ts",
    "types/**/*.d.ts",
    "types/**/*.ts",
    "*.d.ts"
  ]
}
